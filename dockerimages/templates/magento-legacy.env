# Description: Magento 2.4.6 + PHP 8.2 + MariaDB 10.11 + OpenSearch 2.19 + Redis 7.0 + Varnish 8
#
# For consultants on Adobe Commerce / Magento Open Source installations
# still pinned to a 2.4.6 patch level below -p11 (when Valkey was introduced).
# Newer 2.4.6 patches default to Valkey - re-run `make configure PRESET=
# magento-legacy` then flip CACHE_ENGINE=valkey in .env if you have moved
# past -p11. PROJECT_NAME, SITE_HOST and USE_NODE are filled in by the
# wizard. Values are validated against the compatibility matrix in
# dockerimages/bin/init.sh.
FLAVOUR=magento
MAGENTO_VERSION=2.4.6
PHP_VERSION=8.2
DB_ENGINE=mariadb
DB_VERSION=10.11
OPENSEARCH_VERSION=2.19.0
CACHE_ENGINE=redis
USE_VARNISH=yes
