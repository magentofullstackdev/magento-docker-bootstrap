# Description: Magento 2.4.6 + PHP 8.2 + MariaDB 10.6 + OpenSearch 2.5 + Varnish
#
# For consultants on Adobe Commerce / Magento Open Source patches that
# require the 2.4.6 baseline. PROJECT_NAME, SITE_HOST and USE_NODE are
# filled in by the wizard. Values are validated against the compatibility
# matrix in dockerimages/bin/init.sh.
FLAVOUR=magento
MAGENTO_VERSION=2.4.6
PHP_VERSION=8.2
DB_ENGINE=mariadb
DB_VERSION=10.6
OPENSEARCH_VERSION=2.5.0
USE_VARNISH=yes
