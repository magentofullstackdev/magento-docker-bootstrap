# Description: Magento 2.4.8 + PHP 8.4 + MariaDB 11.8 + OpenSearch 3.0 + Valkey 8.1 + Varnish 7.7
#
# The "production today" mainstream preset - sits between magento-latest
# (2.4.9 bleeding edge) and magento-legacy (2.4.6 baseline). Matches Adobe's
# 2.4.8-p5 on-prem certified matrix as of May 2026: Valkey 8.1 (Redis dropped
# from certification), MariaDB 11.8 (added on top of 11.4), Varnish 7.7
# (Adobe deliberately did not bump 2.4.8 to Varnish 8). PROJECT_NAME,
# SITE_HOST and USE_NODE are filled in by the wizard. Values are validated
# against the compatibility matrix in dockerimages/bin/init.sh.
FLAVOUR=magento
MAGENTO_VERSION=2.4.8
PHP_VERSION=8.4
DB_ENGINE=mariadb
DB_VERSION=11.8
OPENSEARCH_VERSION=3.0.0
CACHE_ENGINE=valkey
USE_VARNISH=yes
