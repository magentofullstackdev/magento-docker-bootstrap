# Description: MageOS 2.3.0 + PHP 8.4 + MariaDB 11.4 + OpenSearch 3.0 + Varnish
#
# MageOS-flavoured equivalent of magento-latest — useful when you want a
# community fork without Adobe Marketplace credentials. PROJECT_NAME,
# SITE_HOST and USE_NODE are filled in by the wizard. Values are validated
# against the compatibility matrix in dockerimages/bin/init.sh.
FLAVOUR=mageos
MAGENTO_VERSION=2.3.0
PHP_VERSION=8.4
DB_ENGINE=mariadb
DB_VERSION=11.4
OPENSEARCH_VERSION=3.0.0
USE_VARNISH=yes
