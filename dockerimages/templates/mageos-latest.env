# Description: MageOS 2.3.0 + PHP 8.4 + MariaDB 11.8 + OpenSearch 3.0 + Valkey 8.1 + Varnish 7.7
#
# MageOS-flavoured equivalent of magento-latest - useful when you want a
# community fork without Adobe Marketplace credentials. MageOS upstream stays
# on Varnish 7.7 (no 8 yet) and Valkey 8.1; everything else mirrors Adobe.
# PROJECT_NAME, SITE_HOST and USE_NODE are filled in by the wizard. Values
# are validated against the compatibility matrix in dockerimages/bin/init.sh.
FLAVOUR=mageos
MAGENTO_VERSION=2.3.0
PHP_VERSION=8.4
DB_ENGINE=mariadb
DB_VERSION=11.8
OPENSEARCH_VERSION=3.0.0
CACHE_ENGINE=valkey
USE_VARNISH=yes
