# Description: Magento 2.4.9 + PHP 8.4 + MariaDB 11.4 + OpenSearch 3.0 + Varnish
#
# Stack-only preset for `make configure PRESET=magento-latest`. PROJECT_NAME,
# SITE_HOST and USE_NODE are filled in by the wizard (or by env vars on the
# command line). All values below are validated against the compatibility
# matrix in dockerimages/bin/init.sh — update them in lockstep when the
# matrix moves.
FLAVOUR=magento
MAGENTO_VERSION=2.4.9
PHP_VERSION=8.4
DB_ENGINE=mariadb
DB_VERSION=11.4
OPENSEARCH_VERSION=3.0.0
USE_VARNISH=yes
