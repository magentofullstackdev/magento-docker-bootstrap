# Explicitly exercises the Valkey path on 2.4.7 - a release where the
# matrix offers both redis= and valkey=, so picking CACHE_ENGINE=valkey
# confirms validation accepts it on a "both available" release.
PROJECT_NAME=smoketest
SITE_HOST=smoketest.local
FLAVOUR=magento
MAGENTO_VERSION=2.4.7
PHP_VERSION=8.3
DB_ENGINE=mariadb
DB_VERSION=11.8
OPENSEARCH_VERSION=3.0.0
CACHE_ENGINE=valkey
USE_VARNISH=no
USE_NODE=no
