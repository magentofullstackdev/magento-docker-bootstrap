SITE_HOST=smoketest.local
FLAVOUR=magento
MAGENTO_VERSION=2.4.9
PHP_VERSION=8.4
DB_ENGINE=mariadb
DB_VERSION=11.8
OPENSEARCH_VERSION=3.0.0
USE_VARNISH=no
USE_NODE=no
